# Copy to .env and fill in your values. Do not commit .env to git.

# Supabase (you may already have these)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# 211 API — get these from https://apiportal.211.org after signing up:
# 1. Subscribe to Search (or Search V2) API
# 2. Profile → Subscriptions → Show Primary key → copy as VITE_211_API_KEY
# 3. Open Search API → copy Base URL / Gateway URL as VITE_211_API_BASE_URL (no trailing slash)
VITE_211_API_BASE_URL=
VITE_211_API_KEY=
